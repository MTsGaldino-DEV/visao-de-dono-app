<manifest xmlns:android="http://schemas.android.com/apk/res/android"
          package="expo.modules.notecam">

    <!--
        Android 11+ exige que o app declare explicitamente quais intents quer
        resolver via PackageManager. Declarar a action IMAGE_CAPTURE garante que
        resolveActivity() encontre qualquer app de câmera instalado, sem fixar
        um package específico.
    -->
    <queries>
        <intent>
            <action android:name="android.media.action.IMAGE_CAPTURE" />
        </intent>
    </queries>

    <!--
        Permissão de leitura de imagens do MediaStore — usada pelo fallback que
        lê a foto mais recente quando a câmera ignora o EXTRA_OUTPUT.
        - Android 13+ (API 33+): READ_MEDIA_IMAGES substitui READ_EXTERNAL_STORAGE
        - Android ≤ 12: READ_EXTERNAL_STORAGE ainda é necessário
    -->
    <uses-permission android:name="android.permission.READ_MEDIA_IMAGES" />
    <uses-permission
        android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />

    <application>
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.NotecamFileProvider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/notecam_file_paths" />
        </provider>
    </application>
</manifest>